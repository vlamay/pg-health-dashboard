# PostgreSQL Health Monitor Configuration
# Copy to .env and adjust as needed

# PostgreSQL connection
DATABASE_URL=postgresql://pghealth:pghealth@postgres:5432/pghealth

# Alert thresholds
ALERT_LOCK_WAIT_THRESHOLD_MS=5000
ALERT_LONG_QUERY_THRESHOLD_S=30
ALERT_DEAD_TUPLE_RATIO=0.1

# Metrics refresh interval (seconds)
METRICS_REFRESH_INTERVAL_S=5

# API server
HOST=0.0.0.0
PORT=8000
RELOAD=true
